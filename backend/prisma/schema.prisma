// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===== Organization & User Models =====

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  users    User[]
  leads    Lead[]
  accounts Account[]
  contacts Contact[]
  opportunities Opportunity[]
  tasks    Task[]
  notes    Note[]
  cases    Case[]
  auditLogs AuditLog[]

  @@map("organizations")
}

model User {
  id                String   @id @default(uuid())
  organizationId    String   @map("organization_id")
  firstName         String   @map("first_name")
  lastName          String   @map("last_name")
  email             String   @unique
  passwordHash      String   @map("password_hash")
  refreshTokenHash  String?  @map("refresh_token_hash")
  role              UserRole @default(SALES)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownedLeads        Lead[] @relation("LeadOwner")
  deletedLeads      Lead[] @relation("LeadDeleter")
  restoredLeads     Lead[] @relation("LeadRestorer")
  ownedAccounts     Account[] @relation("AccountOwner")
  deletedAccounts   Account[] @relation("AccountDeleter")
  restoredAccounts  Account[] @relation("AccountRestorer")
  ownedContacts     Contact[] @relation("ContactOwner")
  deletedContacts   Contact[] @relation("ContactDeleter")
  restoredContacts  Contact[] @relation("ContactRestorer")
  ownedOpportunities Opportunity[] @relation("OpportunityOwner")
  stageChangedOpportunities Opportunity[] @relation("OpportunityStageChanger")
  deletedOpportunities Opportunity[] @relation("OpportunityDeleter")
  restoredOpportunities Opportunity[] @relation("OpportunityRestorer")
  ownedTasks        Task[] @relation("TaskOwner")
  assignedTasks     Task[] @relation("TaskAssignee")
  completedTasks    Task[] @relation("TaskCompleter")
  deletedTasks      Task[] @relation("TaskDeleter")
  restoredTasks     Task[] @relation("TaskRestorer")
  ownedNotes        Note[] @relation("NoteOwner")
  ownedCases        Case[] @relation("CaseOwner")
  closedCases       Case[] @relation("CaseCloser")
  deletedCases      Case[] @relation("CaseDeleter")
  restoredCases     Case[] @relation("CaseRestorer")
  convertedLeads    Lead[] @relation("LeadConverter")
  auditLogs         AuditLog[]

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

enum UserRole {
  ADMIN
  MANAGER
  SALES
  SUPPORT
}

// ===== Lead Model =====

model Lead {
  id                     String   @id @default(uuid())
  organizationId         String   @map("organization_id")
  ownerId                String   @map("owner_id")
  firstName              String?  @map("first_name")
  lastName               String   @map("last_name")
  company                String
  title                  String?
  website                String?
  email                  String?
  phone                  String?
  status                 LeadStatus @default(NEW)
  source                 String?
  sourceDetail           String?  @map("source_detail")
  industry               String?
  description            String?
  convertedAccountId     String?  @map("converted_account_id")
  convertedContactId     String?  @map("converted_contact_id")
  convertedOpportunityId String?  @map("converted_opportunity_id")
  convertedAt            DateTime? @map("converted_at")
  convertedById          String?  @map("converted_by_id")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")
  deletedById            String?  @map("deleted_by_id")
  restoredAt             DateTime? @map("restored_at")
  restoredById           String?  @map("restored_by_id")

  // Relations
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner                  User @relation("LeadOwner", fields: [ownerId], references: [id])
  convertedBy            User? @relation("LeadConverter", fields: [convertedById], references: [id], onDelete: SetNull)
  deletedBy              User? @relation("LeadDeleter", fields: [deletedById], references: [id], onDelete: SetNull)
  restoredBy             User? @relation("LeadRestorer", fields: [restoredById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([ownerId])
  @@index([status])
  @@index([convertedById])
  @@index([deletedById])
  @@index([restoredById])
  @@map("leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  NURTURING
  QUALIFIED
  UNQUALIFIED
  CONVERTED
}

// ===== Account Model =====

model Account {
  id                  String   @id @default(uuid())
  organizationId      String   @map("organization_id")
  ownerId             String   @map("owner_id")
  name                String
  website             String?
  type                String?
  phone               String?
  source              String?
  sourceDetail        String?  @map("source_detail")
  description         String?
  billingCountry      String?  @map("billing_country")
  billingStreet       String?  @map("billing_street")
  billingCity         String?  @map("billing_city")
  billingState        String?  @map("billing_state")
  billingPostalCode   String?  @map("billing_postal_code")
  shippingCountry     String?  @map("shipping_country")
  shippingStreet      String?  @map("shipping_street")
  shippingCity        String?  @map("shipping_city")
  shippingState       String?  @map("shipping_state")
  shippingPostalCode  String?  @map("shipping_postal_code")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")
  deletedById         String?  @map("deleted_by_id")
  restoredAt          DateTime? @map("restored_at")
  restoredById        String?  @map("restored_by_id")

  // Relations
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner               User @relation("AccountOwner", fields: [ownerId], references: [id])
  deletedBy           User? @relation("AccountDeleter", fields: [deletedById], references: [id], onDelete: SetNull)
  restoredBy          User? @relation("AccountRestorer", fields: [restoredById], references: [id], onDelete: SetNull)
  contacts            Contact[]
  opportunities       Opportunity[]
  cases               Case[]

  @@index([organizationId])
  @@index([ownerId])
  @@index([deletedById])
  @@index([restoredById])
  @@map("accounts")
}

// ===== Contact Model =====

model Contact {
  id                 String   @id @default(uuid())
  organizationId     String   @map("organization_id")
  ownerId            String   @map("owner_id")
  accountId          String   @map("account_id")
  firstName          String?  @map("first_name")
  lastName           String   @map("last_name")
  title              String?
  email              String?
  phone              String?
  source             String?
  sourceDetail       String?  @map("source_detail")
  description        String?
  mailingCountry     String?  @map("mailing_country")
  mailingStreet      String?  @map("mailing_street")
  mailingCity        String?  @map("mailing_city")
  mailingState       String?  @map("mailing_state")
  mailingPostalCode  String?  @map("mailing_postal_code")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")
  deletedById        String?  @map("deleted_by_id")
  restoredAt         DateTime? @map("restored_at")
  restoredById       String?  @map("restored_by_id")

  // Relations
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner              User @relation("ContactOwner", fields: [ownerId], references: [id])
  deletedBy          User? @relation("ContactDeleter", fields: [deletedById], references: [id], onDelete: SetNull)
  restoredBy         User? @relation("ContactRestorer", fields: [restoredById], references: [id], onDelete: SetNull)
  account            Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  opportunities      Opportunity[]
  cases              Case[]

  @@index([organizationId])
  @@index([ownerId])
  @@index([accountId])
  @@index([deletedById])
  @@index([restoredById])
  @@map("contacts")
}

// ===== Opportunity Model =====

model Opportunity {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  ownerId         String   @map("owner_id")
  accountId       String   @map("account_id")
  contactId       String?  @map("contact_id")
  name            String
  stage           OpportunityStage @default(QUALIFY)
  amount          Decimal? @db.Decimal(15, 2)
  closeDate       DateTime? @map("close_date")
  nextStep        String?  @map("next_step")
  source          String?
  sourceDetail    String?  @map("source_detail")
  description     String?
  stageChangedAt  DateTime? @map("stage_changed_at")
  stageChangedById String? @map("stage_changed_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  deletedById     String?  @map("deleted_by_id")
  restoredAt      DateTime? @map("restored_at")
  restoredById    String?  @map("restored_by_id")

  // Relations
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner           User @relation("OpportunityOwner", fields: [ownerId], references: [id])
  stageChangedBy  User? @relation("OpportunityStageChanger", fields: [stageChangedById], references: [id], onDelete: SetNull)
  deletedBy       User? @relation("OpportunityDeleter", fields: [deletedById], references: [id], onDelete: SetNull)
  restoredBy      User? @relation("OpportunityRestorer", fields: [restoredById], references: [id], onDelete: SetNull)
  account         Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact         Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([ownerId])
  @@index([accountId])
  @@index([contactId])
  @@index([stage])
  @@index([stageChangedById])
  @@index([deletedById])
  @@index([restoredById])
  @@map("opportunities")
}

enum OpportunityStage {
  QUALIFY
  PROPOSE
  NEGOTIATE
  CLOSED_WON
  CLOSED_LOST
}

// ===== Task Model =====

model Task {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  ownerId         String   @map("owner_id")
  assignedToId    String   @map("assigned_to_id")
  subject         String
  dueDate         DateTime? @map("due_date")
  status          TaskStatus @default(NOT_STARTED)
  priority        TaskPriority @default(NORMAL)
  relatedType     String?  @map("related_type")
  relatedId       String?  @map("related_id")
  description     String?
  completedAt     DateTime? @map("completed_at")
  completedById   String?  @map("completed_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  deletedById     String?  @map("deleted_by_id")
  restoredAt      DateTime? @map("restored_at")
  restoredById    String?  @map("restored_by_id")

  // Relations
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner           User @relation("TaskOwner", fields: [ownerId], references: [id])
  assignedTo      User @relation("TaskAssignee", fields: [assignedToId], references: [id])
  completedBy     User? @relation("TaskCompleter", fields: [completedById], references: [id], onDelete: SetNull)
  deletedBy       User? @relation("TaskDeleter", fields: [deletedById], references: [id], onDelete: SetNull)
  restoredBy      User? @relation("TaskRestorer", fields: [restoredById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([ownerId])
  @@index([assignedToId])
  @@index([status])
  @@index([completedById])
  @@index([deletedById])
  @@index([restoredById])
  @@map("tasks")
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
}

// ===== Note Model =====

model Note {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  ownerId         String   @map("owner_id")
  content         String
  relatedType     String   @map("related_type")
  relatedId       String   @map("related_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  // Relations
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner           User @relation("NoteOwner", fields: [ownerId], references: [id])

  @@index([organizationId])
  @@index([ownerId])
  @@index([relatedType])
  @@index([relatedId])
  @@map("notes")
}

// ===== Case Model =====

model Case {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  ownerId         String   @map("owner_id")
  accountId       String?  @map("account_id")
  contactId       String?  @map("contact_id")
  subject         String
  status          CaseStatus @default(NEW)
  priority        CasePriority @default(MEDIUM)
  source          String?
  sourceDetail    String?  @map("source_detail")
  description     String?
  closedAt        DateTime? @map("closed_at")
  closedById      String?  @map("closed_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  deletedById     String?  @map("deleted_by_id")
  restoredAt      DateTime? @map("restored_at")
  restoredById    String?  @map("restored_by_id")

  // Relations
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner           User @relation("CaseOwner", fields: [ownerId], references: [id])
  closedBy        User? @relation("CaseCloser", fields: [closedById], references: [id], onDelete: SetNull)
  deletedBy       User? @relation("CaseDeleter", fields: [deletedById], references: [id], onDelete: SetNull)
  restoredBy      User? @relation("CaseRestorer", fields: [restoredById], references: [id], onDelete: SetNull)
  account         Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  contact         Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([ownerId])
  @@index([accountId])
  @@index([contactId])
  @@index([status])
  @@index([closedById])
  @@index([deletedById])
  @@index([restoredById])
  @@map("cases")
}

enum CaseStatus {
  NEW
  WORKING
  RESOLVED
  CLOSED
}

enum CasePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  action         String
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id")
  oldValues      Json?    @map("old_values")
  newValues      Json?    @map("new_values")
  createdAt      DateTime @default(now()) @map("created_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@map("audit_logs")
}
