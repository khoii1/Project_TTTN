# Database
# Runtime can use Supabase transaction pooler, for example:
# postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=
# Prisma migration should use Supabase Session pooler on port 5432,
# or the direct database host if your environment supports it.
DIRECT_URL=

# JWT
JWT_ACCESS_TOKEN_SECRET=
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_SECRET=
JWT_REFRESH_TOKEN_EXPIRATION=7d

# API
# PORT is often provided automatically by hosting platforms such as Render/Railway.
# API_PORT is used as a fallback/local port if PORT is not provided.
PORT=
API_PORT=3000
API_VERSION=v1
CORS_ORIGIN=https://your-frontend-domain.com
NODE_ENV=production

# Bcrypt
BCRYPT_ROUNDS=10
